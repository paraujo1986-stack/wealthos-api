# ─────────────────────────────────────────────────────────────
# WealthOS API — variáveis de ambiente
# Copiar para .env e preencher ANTES de arrancar o servidor
# ─────────────────────────────────────────────────────────────

# Base de dados (Supabase → Settings → Database → URI mode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# JWT Secrets — gerar com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GERAR_SECRET_MINIMO_64_BYTES"
JWT_REFRESH_SECRET="GERAR_OUTRO_SECRET_DIFERENTE"

# Servidor
PORT=3000
NODE_ENV=development

# CORS — domínios permitidos (separados por vírgula)
# Em dev podes usar *
# Em produção usa o domínio real do frontend
ALLOWED_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"
